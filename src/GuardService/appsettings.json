{
  "Guard": {
    "PollIntervalSeconds": 30,
    "TargetProcessName": "Ecloud Cloud Computer Application.exe",
    "TargetExecutablePath": "",
    "DesktopTitleKeywords": [],
    "DesktopClassKeywords": [],
    "MinimumDesktopWidth": 1000,
    "MinimumDesktopHeight": 700,
    "RequireVisibleWindow": true,
    "AllowMinimizedWindow": false,
    "AutoStartWhenNotRunning": true,
    "StartProcessWaitMilliseconds": 5000,
    "EnableLoginAssist": true,
    "LoginClickTimeoutMs": 3000,
    "LoginAssistCooldownSeconds": 10,
    "AllowMouseFallback": true,
    "LoginButtonKeywords": [
      "登录",
      "立即登录",
      "Login"
    ],
    "EnableTestMode": false,
    "TestModeLoopCount": 3,
    "HeadlessWindowOnly": true,
    "AutomationDiagnosticsPath": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "GuardService": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}